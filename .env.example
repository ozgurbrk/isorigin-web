# Sitenin yayın adresi (SEO / OG / sitemap için). Örn: https://isorigin.com
NEXT_PUBLIC_SITE_URL=https://isorigin.com

# Turso (libSQL) veritabanı
# Prod: turso db show <db> --url   ->  libsql://...
# Lokal geliştirme için: file:local.db (token boş bırakılabilir)
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Admin paneli girişi
ADMIN_PASSWORD=degistir-beni
# Cookie imzalama için rastgele uzun bir string (ör: openssl rand -hex 32)
SESSION_SECRET=lutfen-rastgele-uzun-bir-deger-girin

# Yayın verisi yenileme uç noktası için gizli anahtar
# Manuel çağrı: GET /api/refresh-live?secret=...
REFRESH_SECRET=rastgele-bir-yenileme-anahtari
# Vercel Cron için (Vercel cron isteklerine otomatik Authorization: Bearer ekler)
CRON_SECRET=rastgele-bir-cron-anahtari

# Twitch resmi API (https://dev.twitch.tv/console/apps - ücretsiz)
# TikTok ve Kick anahtar gerektirmez.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
